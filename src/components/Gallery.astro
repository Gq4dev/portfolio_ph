---
import OptimizedImage from './OptimizedImage.astro'
import { urlFor } from '../lib/image'
import type { SanityImage } from '../lib/queries'

interface Props {
  photos: SanityImage[]
  title: string
}

const { photos, title } = Astro.props

// Precompute the large lightbox URL server-side (no urlFor on the client).
const items = photos.map((photo, i) => ({
  photo,
  index: i,
  num: String(i + 1).padStart(2, '0'),
  full: urlFor(photo).width(2000).auto('format').quality(85).url(),
  alt: photo.alt ?? title,
  caption: photo.caption ?? '',
}))
---

{
  items.length === 0 ? (
    <p class="gallery-empty wrap" data-reveal>
      <span data-lang-block="en">There are no photos in this series yet.</span>
      <span data-lang-block="es">Todavía no hay fotografías en esta serie.</span>
    </p>
  ) : (
    <div class="gallery wrap">
      {items.map((it) => (
        <button
          class="shot"
          type="button"
          data-lightbox-open
          data-index={it.index}
          data-full={it.full}
          data-alt={it.alt}
          data-caption={it.caption}
          data-reveal
          style={`--reveal-delay:${(it.index % 3) * 0.08}s`}
          aria-label={`Ampliar foto ${it.num}: ${it.alt}`}
        >
          <OptimizedImage
            image={it.photo}
            alt={it.alt}
            sizes="(max-width: 640px) 92vw, (max-width: 1000px) 46vw, 30vw"
            class="shot__img"
          />
          <span class="shot__cap" aria-hidden="true">
            {it.caption || it.alt}
          </span>
        </button>
      ))}
    </div>
  )
}

<!-- Accessible lightbox -->
<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Visor de fotografía ampliada"
  hidden
>
  <button class="lightbox__close" type="button" data-lightbox-close aria-label="Cerrar visor">
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <button class="lightbox__nav lightbox__nav--prev" type="button" data-lightbox-prev aria-label="Foto anterior">
    <svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 5l-7 7 7 7"/></svg>
  </button>
  <figure class="lightbox__stage">
    <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    <figcaption class="lightbox__caption">
      <span id="lightbox-text"></span>
    </figcaption>
  </figure>
  <button class="lightbox__nav lightbox__nav--next" type="button" data-lightbox-next aria-label="Foto siguiente">
    <svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<style>
  .gallery-empty {
    color: var(--text-dim);
    font-size: var(--step-1);
    padding-block: 4rem;
  }

  /* Masonry via CSS columns — organic, editorial, no rigid rows. */
  .gallery {
    column-count: 1;
    column-gap: clamp(1rem, 2vw, 2rem);
  }
  @media (min-width: 640px) {
    .gallery {
      column-count: 2;
    }
  }
  @media (min-width: 1000px) {
    .gallery {
      column-count: 3;
    }
  }

  .shot {
    display: block;
    position: relative;
    width: 100%;
    padding: 0;
    margin: 0 0 clamp(1rem, 2vw, 2rem);
    break-inside: avoid;
    overflow: hidden;
    background: var(--surface);
    text-align: left;
  }
  /* Editorial off-grid nudge: lift every 3rd shot. */
  .shot:nth-child(3n) {
    margin-top: clamp(0.5rem, 3vw, 2.5rem);
  }

  .shot :global(.shot__img) {
    transition: transform 0.9s var(--ease-out), filter 0.6s var(--ease);
    filter: saturate(0.94) brightness(0.98);
  }
  .shot:hover :global(.shot__img),
  .shot:focus-visible :global(.shot__img) {
    transform: scale(1.04);
    filter: saturate(1.05) brightness(1);
  }

  /* Hover: reveal caption/title over the image. */
  .shot__cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    padding: 1.4rem 0.9rem 0.85rem;
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--text);
    background: linear-gradient(
      to top,
      rgba(15, 15, 17, 0.9),
      rgba(15, 15, 17, 0)
    );
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .shot:hover .shot__cap,
  .shot:focus-visible .shot__cap {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .shot__cap {
      transition: none;
    }
  }

  /* ---------------- Lightbox ----------------
     Always dark, regardless of the site theme — a full-screen photo viewer
     reads best on black. Local vars keep its controls legible on that dark
     backdrop in both light and dark site themes. */
  .lightbox {
    --lb-fg: #ece4d8;
    --lb-line: rgba(255, 255, 255, 0.16);
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(0.25rem, 2vw, 1.5rem);
    padding: clamp(0.75rem, 3vw, 2.5rem);
    background: rgba(12, 12, 14, 0.95);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox.is-open {
    opacity: 1;
  }

  .lightbox__stage {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-width: 0;
    height: 100%;
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }
  .lightbox__caption {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    font-size: var(--step--1);
    color: color-mix(in srgb, var(--lb-fg) 65%, transparent);
  }
  .lightbox__close {
    position: absolute;
    top: clamp(0.75rem, 3vw, 2rem);
    right: clamp(0.75rem, 3vw, 2rem);
    z-index: 2;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--lb-fg);
    border: 1px solid var(--lb-line);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease),
      transform 0.25s var(--ease);
  }
  .lightbox__close:hover {
    color: var(--accent-bright);
    border-color: var(--accent-bright);
    transform: rotate(90deg);
  }

  .lightbox__nav {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    color: color-mix(in srgb, var(--lb-fg) 70%, transparent);
    border: 1px solid transparent;
    border-radius: 50%;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease),
      background 0.25s var(--ease);
  }
  .lightbox__nav:hover {
    color: var(--lb-fg);
    border-color: var(--lb-line);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 640px) {
    /* Carousel arrows centered vertically on the sides, over the image. */
    .lightbox__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      background: color-mix(in srgb, rgba(12, 12, 14, 1) 55%, transparent);
      backdrop-filter: blur(4px);
    }
    .lightbox__nav--prev {
      left: 0.4rem;
    }
    .lightbox__nav--next {
      right: 0.4rem;
    }
  }
</style>

<script>
  interface Slide {
    full: string
    alt: string
    caption: string
    num: string
    trigger: HTMLElement
  }

  function initLightbox() {
    const box = document.getElementById('lightbox')
    if (!box) return

    const img = document.getElementById('lightbox-img') as HTMLImageElement | null
    const textEl = document.getElementById('lightbox-text')
    if (!img || !textEl) return

    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>('[data-lightbox-open]')
    )

    const slides: Slide[] = triggers.map((t) => ({
      full: t.dataset.full || '',
      alt: t.dataset.alt || '',
      caption: t.dataset.caption || '',
      num: String(Number(t.dataset.index) + 1).padStart(2, '0'),
      trigger: t,
    }))

    let current = 0
    let lastFocused: HTMLElement | null = null

    const render = () => {
      const s = slides[current]
      if (!s) return
      img.src = s.full
      img.alt = s.alt
      textEl.textContent = s.caption || s.alt
    }

    const open = (index: number) => {
      current = index
      lastFocused = document.activeElement as HTMLElement
      render()
      box.hidden = false
      // next frame → CSS transition
      requestAnimationFrame(() => box.classList.add('is-open'))
      document.body.style.overflow = 'hidden'
      ;(box.querySelector('[data-lightbox-close]') as HTMLElement)?.focus()
    }

    const close = () => {
      box.classList.remove('is-open')
      document.body.style.overflow = ''
      const done = () => {
        box.hidden = true
        box.removeEventListener('transitionend', done)
      }
      // respect reduced motion (no transition → hide immediately)
      if (
        window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        box.hidden = true
      } else {
        box.addEventListener('transitionend', done)
      }
      lastFocused?.focus()
    }

    const go = (dir: number) => {
      current = (current + dir + slides.length) % slides.length
      render()
    }

    triggers.forEach((t, i) =>
      t.addEventListener('click', () => open(i))
    )
    box
      .querySelector('[data-lightbox-close]')
      ?.addEventListener('click', close)
    box
      .querySelector('[data-lightbox-prev]')
      ?.addEventListener('click', () => go(-1))
    box
      .querySelector('[data-lightbox-next]')
      ?.addEventListener('click', () => go(1))

    // backdrop click (only when the grid container itself is clicked)
    box.addEventListener('click', (e) => {
      if (e.target === box) close()
    })

    // keyboard: Esc / arrows + focus trap
    box.addEventListener('keydown', (e) => {
      if (box.hidden) return
      if (e.key === 'Escape') {
        close()
      } else if (e.key === 'ArrowRight') {
        go(1)
      } else if (e.key === 'ArrowLeft') {
        go(-1)
      } else if (e.key === 'Tab') {
        const focusables = box.querySelectorAll<HTMLElement>(
          'button:not([disabled])'
        )
        if (!focusables.length) return
        const first = focusables[0]
        const last = focusables[focusables.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault()
          last.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault()
          first.focus()
        }
      }
    })

    // Touch swipe (mobile): swipe left → next photo, right → previous.
    let touchX = 0
    let touchY = 0
    box.addEventListener(
      'touchstart',
      (e) => {
        touchX = e.changedTouches[0].screenX
        touchY = e.changedTouches[0].screenY
      },
      { passive: true }
    )
    box.addEventListener(
      'touchend',
      (e) => {
        if (box.hidden) return
        const dx = e.changedTouches[0].screenX - touchX
        const dy = e.changedTouches[0].screenY - touchY
        // Horizontal intent only, past a minimum distance — ignore taps/scrolls.
        if (Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy)) {
          go(dx < 0 ? 1 : -1)
        }
      },
      { passive: true }
    )
  }

  initLightbox()
  document.addEventListener('astro:page-load', initLightbox)
</script>
