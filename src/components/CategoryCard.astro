---
import OptimizedImage from './OptimizedImage.astro'
import { photoCountShort } from '../lib/i18n'
import type { CategorySummary } from '../lib/queries'

interface Props {
  category: CategorySummary
  index: number
  /** Columns to span at the 3-col breakpoint. 3 = full-width featured card
      that fills an orphan row; 2 = fills the tail of a two-orphan row. */
  span?: 1 | 2 | 3
}

const { category, index, span = 1 } = Astro.props
const label = photoCountShort(category.photoCount)
// sizes tracks the real render: 1-col <720px, 2-col 720–1100px, span at >1100px.
const desktopVw = span === 3 ? '92vw' : span === 2 ? '62vw' : '31vw'
const imgSizes = `(max-width: 720px) 92vw, (max-width: 1100px) 46vw, ${desktopVw}`
---

<a
  class:list={[
    'card',
    span === 3 && 'card--span3',
    span === 2 && 'card--span2',
  ]}
  href={`/${category.slug}`}
  data-reveal
  style={`--reveal-delay:${index * 0.09}s`}
  aria-label={`${category.titleEn} — ${label.en}`}
>
  <div class="card__frame">
    {
      category.cover ? (
        <OptimizedImage
          image={category.cover}
          alt={category.cover.alt ?? category.title}
          sizes={imgSizes}
          class="card__img"
        />
      ) : (
        <div class="card__empty" aria-hidden="true" />
      )
    }
  </div>

  <div class="card__meta">
    <h3 class="card__title">
      <span data-lang-block="en">{category.titleEn}</span
      ><span data-lang-block="es">{category.title}</span>
    </h3>
    <span class="card__count">
      <span data-lang-block="en">{label.en}</span
      ><span data-lang-block="es">{label.es}</span>
    </span>
    <span class="card__go" aria-hidden="true">
      <span data-lang-block="en">View series →</span
      ><span data-lang-block="es">Ver serie →</span>
    </span>
  </div>
</a>

<style>
  .card {
    display: block;
    color: inherit;
  }
  /* Orphan-fill at the 3-col breakpoint. The featured card spans the wider
     row and shows its cover at its NATURAL proportions — no fixed ratio, no
     crop. The doubled `.card` class raises specificity so this wins over both
     the base card ratio and OptimizedImage's figure aspect-ratio. Below
     1100px the grid is 2-/1-col and closes on its own, so this must NOT apply. */
  @media (min-width: 1100px) {
    .card--span2 {
      grid-column: span 2;
    }
    .card--span3 {
      grid-column: span 3;
    }
    .card--span2.card :global(.card__img),
    .card--span3.card :global(.card__img) {
      aspect-ratio: auto;
    }
  }
  .card__frame {
    position: relative;
    overflow: hidden;
    background: var(--surface);
  }
  .card__empty {
    aspect-ratio: 3 / 2;
    background: repeating-linear-gradient(
      45deg,
      var(--surface),
      var(--surface) 12px,
      var(--surface-2) 12px,
      var(--surface-2) 24px
    );
  }

  .card :global(.card__img) {
    aspect-ratio: 4 / 5;
    transition: transform 0.9s var(--ease-out), filter 0.6s var(--ease);
    filter: saturate(0.92);
  }
  .card:hover :global(.card__img),
  .card:focus-visible :global(.card__img) {
    transform: scale(1.045);
    filter: saturate(1.05);
  }

  .card__meta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 0.4rem 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    margin-top: 0.9rem;
  }
  .card__title {
    font-size: var(--step-3);
    grid-row: 1;
    transition: color 0.3s var(--ease);
  }
  .card:hover .card__title {
    color: var(--accent-bright);
  }
  .card__count {
    grid-row: 1;
    justify-self: end;
    align-self: center;
    font-size: var(--step--1);
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
  .card__go {
    grid-column: 1 / -1;
    font-size: var(--step--1);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease),
      color 0.3s var(--ease);
  }
  .card:hover .card__go,
  .card:focus-visible .card__go {
    opacity: 1;
    transform: none;
    color: var(--accent);
  }
</style>
