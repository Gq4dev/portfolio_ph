---
import '@fontsource-variable/playfair-display'
import '@fontsource/space-grotesk/400.css'
import '@fontsource/space-grotesk/500.css'
import '@fontsource/space-grotesk/700.css'
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import { getSiteSettings, getCategories } from '../lib/queries'
import { urlFor } from '../lib/image'

interface Props {
  title: string
  description?: string
  /** LCP image to preload (responsive). Pass the hero's srcset + sizes. */
  preloadSrcset?: string
  preloadSizes?: string
}

const { title, description, preloadSrcset, preloadSizes } = Astro.props

const [settings, categories] = await Promise.all([
  getSiteSettings(),
  getCategories(),
])

const brand = settings.title
const metaDescription =
  description ||
  settings.shortBioEn ||
  settings.shortBio ||
  `${settings.title} — ${settings.tagline}. Photography portfolio.`

// Canonical + Open Graph. Astro.site comes from astro.config (set per env).
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href
const ogSource =
  settings.featured[0] ?? categories.find((c) => c.cover)?.cover ?? null
const ogImage = ogSource
  ? urlFor(ogSource).width(1200).height(630).fit('crop').auto('format').url()
  : null

// Structured data: identifies the site owner as a photographer and links her
// Instagram as an official profile (sameAs) for search engines / knowledge graph.
const sameAs: string[] = []
if (settings.instagram) {
  sameAs.push(`https://instagram.com/${settings.instagram.replace('@', '')}`)
}
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: settings.title,
  jobTitle: 'Photographer',
  description:
    settings.shortBioEn || settings.shortBio || `${settings.title} — ${settings.tagline}`,
  url: Astro.site ? Astro.site.href : canonical,
  ...(sameAs.length ? { sameAs } : {}),
  ...(settings.email ? { email: `mailto:${settings.email}` } : {}),
  ...(ogImage ? { image: ogImage } : {}),
}
// Escape "<" so a stray "</script>" in CMS text can't break out of the tag.
const jsonLdStr = JSON.stringify(jsonLd).replace(/</g, '\\u003c')

// Umami analytics — self-hosted. Set both PUBLIC_UMAMI_SRC and PUBLIC_UMAMI_ID
// in the build env once the Umami instance is up; until then, nothing loads.
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC || ''
const umamiId = import.meta.env.PUBLIC_UMAMI_ID || ''
---

<!doctype html>
<html lang="en" data-lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Anti-flash: apply the saved theme before first paint. Default dark, so
      // no-JS visitors keep the branded dark palette.
      try {
        var t = localStorage.getItem('theme')
        document.documentElement.setAttribute(
          'data-theme',
          t === 'light' ? 'light' : 'dark'
        )
      } catch (e) {}
    </script>
    <meta name="description" content={metaDescription} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    {
      preloadSrcset && (
        <link
          rel="preload"
          as="image"
          imagesrcset={preloadSrcset}
          imagesizes={preloadSizes}
          fetchpriority="high"
        />
      )
    }
    <title>{title}</title>

    <!-- Open Graph / Twitter — link previews on WhatsApp, IG, X, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script type="application/ld+json" set:html={jsonLdStr} is:inline />

    {
      umamiSrc && umamiId && (
        <script defer src={umamiSrc} data-website-id={umamiId} is:inline />
      )
    }

    <ClientRouter />
  </head>
  <body>
    <a class="skip" href="#main">
      <span data-lang-block="en">Skip to content</span
      ><span data-lang-block="es">Saltar al contenido</span>
    </a>

    <header class="nav wrap" transition:persist>
      <a class="nav__brand" href="/">{brand}</a>

      <div class="nav__cluster">
        <nav class="nav__panel" aria-label="Main navigation">
          <ul class="nav__links" id="nav-links">
          {
            categories.length > 0 && (
              <li class="nav__dropdown">
                <button
                  class="nav__trigger"
                  type="button"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="nav-galerias"
                >
                  <span data-lang-block="en">Galleries</span>
                  <span data-lang-block="es">Galerías</span>
                </button>
                <ul class="nav__menu" id="nav-galerias" hidden>
                  {categories.map((c) => (
                    <li>
                      <a href={`/${c.slug}`}>{c.title}</a>
                    </li>
                  ))}
                </ul>
              </li>
            )
          }
          <li>
            <a href="/sobre">
              <span data-lang-block="en">About</span
              ><span data-lang-block="es">Sobre</span>
            </a>
          </li>
          <li>
            <a href="/contacto">
              <span data-lang-block="en">Contact</span
              ><span data-lang-block="es">Contacto</span>
            </a>
          </li>
        </ul>
        </nav>

        <div class="nav__utils">
          <div class="lang" role="group" aria-label="Language / Idioma">
            <button
              class="lang__opt"
              type="button"
              data-set-lang="en"
              aria-pressed="true">EN</button
            ><span class="lang__sep" aria-hidden="true">/</span
            ><button
              class="lang__opt"
              type="button"
              data-set-lang="es"
              aria-pressed="false">ES</button
            >
          </div>
          <button
            class="theme"
            type="button"
            data-theme-toggle
            aria-label="Switch to light theme"
          >
            <svg
              class="theme__icon theme__icon--sun"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4.2" />
              <path
                d="M12 2v2.5M12 19.5V22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M2 12h2.5M19.5 12H22M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8"
              />
            </svg>
            <svg
              class="theme__icon theme__icon--moon"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              aria-hidden="true"
            >
              <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z" />
            </svg>
          </button>
        </div>

        <button
          class="nav__burger"
          type="button"
          aria-expanded="false"
          aria-controls="nav-links"
          aria-label="Open menu"
          data-nav-burger
        >
          <span class="nav__burger-lines" aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer wrap">
      <hr class="rule" />
      <div class="footer__row">
        <p class="footer__brand">{brand}</p>
        <ul class="footer__meta">
          {settings.instagram && (
            <li>
              <a
                class="footer__ig"
                href={`https://instagram.com/${settings.instagram.replace('@', '')}`}
                rel="me noopener"
                target="_blank"
                aria-label="Instagram"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  aria-hidden="true"
                >
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
                </svg>
              </a>
            </li>
          )}
          {settings.email && (
            <li><a href={`mailto:${settings.email}`}>{settings.email}</a></li>
          )}
          <li><span>© {new Date().getFullYear()}</span></li>
        </ul>
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        z-index: 200;
        padding: 0.6rem 1rem;
        background: var(--accent);
        color: var(--bg);
        font-weight: 500;
        transform: translateY(-160%);
        transition: transform 0.2s var(--ease);
      }
      .skip:focus {
        transform: translateY(0);
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding-block: clamp(1rem, 2vw, 1.6rem);
        border-bottom: 1px solid var(--line);
      }
      /* Header background/blur lives on a pseudo-element, NOT on .nav itself:
         backdrop-filter on .nav creates a containing block that would trap the
         mobile menu's position:fixed overlay inside the header box. */
      .nav::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -1;
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: blur(12px);
      }
      .nav__brand {
        font-family: var(--font-display);
        font-size: var(--step-1);
        font-weight: 400;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      /* Right-side group: nav links + utility toggles + (mobile) burger. */
      .nav__cluster {
        display: flex;
        align-items: center;
        gap: clamp(0.9rem, 2.4vw, 2.2rem);
      }
      .nav__utils {
        display: flex;
        align-items: center;
        gap: clamp(0.75rem, 2vw, 1.2rem);
      }
      .nav__links {
        display: flex;
        align-items: center;
        gap: clamp(0.9rem, 2.4vw, 2.2rem);
        font-size: var(--step--1);
        letter-spacing: 0.02em;
      }
      .nav__links a {
        position: relative;
        padding-block: 0.2rem;
        color: var(--text-dim);
        transition: color 0.3s var(--ease);
      }
      .nav__links a::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s var(--ease);
      }
      .nav__links a:hover,
      .nav__links a:focus-visible {
        color: var(--text);
      }
      .nav__links a:hover::after,
      .nav__links a:focus-visible::after {
        transform: scaleX(1);
      }

      /* ---- Galerías dropdown ---- */
      .nav__dropdown {
        position: relative;
      }
      .nav__trigger {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.2rem 0;
        font-family: inherit;
        font-size: var(--step--1);
        letter-spacing: 0.02em;
        color: var(--text-dim);
        transition: color 0.3s var(--ease);
      }
      .nav__trigger::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s var(--ease);
      }
      .nav__trigger:hover,
      .nav__trigger:focus-visible,
      .nav__trigger[aria-expanded='true'] {
        color: var(--text);
      }
      .nav__trigger:hover::after,
      .nav__trigger:focus-visible::after,
      .nav__trigger[aria-expanded='true']::after {
        transform: scaleX(1);
      }

      .nav__menu {
        position: absolute;
        top: calc(100% + 0.9rem);
        left: 0;
        z-index: 120;
        display: grid;
        gap: 0.15rem;
        min-width: max(11rem, 100%);
        max-width: min(72vw, 18rem);
        padding: 0.5rem;
        background: color-mix(in srgb, var(--surface) 92%, transparent);
        backdrop-filter: blur(14px);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.45);
      }
      .nav__menu[hidden] {
        display: none;
      }
      .nav__menu li {
        margin: 0;
      }
      .nav__menu a {
        display: block;
        padding: 0.55rem 0.7rem;
        font-size: var(--step--1);
        letter-spacing: 0.02em;
        color: var(--text-dim);
        border-radius: var(--radius);
        transition: color 0.25s var(--ease), background 0.25s var(--ease);
      }
      .nav__menu a:hover,
      .nav__menu a:focus-visible {
        color: var(--text);
        background: color-mix(in srgb, var(--accent) 16%, transparent);
        outline: none;
      }
      /* ---- Mobile hamburger ---- */
      .nav__burger {
        display: none;
      }
      @media (max-width: 640px) {
        .nav__burger {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          width: 2.4rem;
          height: 2.4rem;
          color: var(--text);
          position: relative;
          z-index: 130; /* above the full-screen overlay */
        }
        .nav__burger-lines,
        .nav__burger-lines::before,
        .nav__burger-lines::after {
          display: block;
          width: 22px;
          height: 1.6px;
          background: currentColor;
          transition: transform 0.3s var(--ease), background 0.2s var(--ease);
        }
        .nav__burger-lines {
          position: relative;
        }
        .nav__burger-lines::before,
        .nav__burger-lines::after {
          content: '';
          position: absolute;
          left: 0;
        }
        .nav__burger-lines::before {
          top: -7px;
        }
        .nav__burger-lines::after {
          top: 7px;
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines {
          background: transparent;
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines::before {
          transform: translateY(7px) rotate(45deg);
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines::after {
          transform: translateY(-7px) rotate(-45deg);
        }

        /* Toggles stay in the header, above the overlay, always usable. */
        .nav__utils {
          position: relative;
          z-index: 130;
          gap: 0.9rem;
        }

        /* Nav links become a full-screen centered overlay. */
        .nav__panel {
          position: fixed;
          inset: 0;
          z-index: 120;
          display: flex;
          overflow-y: auto;
          /* Dims the site behind while covering the full viewport. */
          background: color-mix(in srgb, var(--bg) 86%, transparent);
          backdrop-filter: blur(16px);
          opacity: 0;
          visibility: hidden;
          transition: opacity 0.4s var(--ease), visibility 0s linear 0.4s;
        }
        .nav[data-menu-open='true'] .nav__panel {
          opacity: 1;
          visibility: visible;
          transition: opacity 0.4s var(--ease), visibility 0s linear 0s;
        }
        .nav__links {
          margin: auto;
          padding: 5rem 1.5rem 3rem;
          flex-direction: column;
          align-items: center;
          gap: clamp(1.5rem, 5vh, 2.6rem);
          font-size: var(--step-3);
          text-align: center;
        }
        .nav__links a,
        .nav__trigger {
          color: var(--text);
        }
        /* Staggered entrance for the options once the overlay is open. */
        .nav__links > li {
          opacity: 0;
          transform: translateY(14px);
          transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
        }
        .nav[data-menu-open='true'] .nav__links > li {
          opacity: 1;
          transform: none;
        }
        .nav[data-menu-open='true'] .nav__links > li:nth-child(1) {
          transition-delay: 0.1s;
        }
        .nav[data-menu-open='true'] .nav__links > li:nth-child(2) {
          transition-delay: 0.16s;
        }
        .nav[data-menu-open='true'] .nav__links > li:nth-child(3) {
          transition-delay: 0.22s;
        }
        .nav__trigger {
          font-size: var(--step-3);
        }

        /* Galleries submenu: centered under the trigger. */
        .nav__menu {
          position: static;
          min-width: 0;
          max-width: none;
          margin-top: 1rem;
          padding: 0;
          background: transparent;
          border: none;
          box-shadow: none;
          backdrop-filter: none;
          justify-items: center;
          gap: 0.5rem;
        }
        .nav__menu a {
          font-size: var(--step-0);
          text-align: center;
        }
      }

      .footer {
        margin-top: clamp(4rem, 10vw, 9rem);
        padding-bottom: 2.5rem;
      }
      .footer__row {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 1.5rem;
      }
      .footer__brand {
        font-family: var(--font-display);
        font-size: var(--step-2);
      }
      .footer__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.4rem;
        font-size: var(--step--1);
        color: var(--text-dim);
      }
      .footer__meta a:hover {
        color: var(--accent);
      }
      .footer__ig {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      /* ---- Language toggle (EN / ES, active highlighted) ---- */
      .nav__lang {
        display: inline-flex;
      }
      .lang {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: var(--step--1);
        letter-spacing: 0.08em;
      }
      .lang__opt {
        color: var(--text-dim);
        transition: color 0.25s var(--ease);
      }
      .lang__opt:hover,
      .lang__opt:focus-visible {
        color: var(--text);
      }
      /* Active language: highlighted and non-interactive-looking. */
      :global(html[data-lang='en']) .lang__opt[data-set-lang='en'],
      :global(html[data-lang='es']) .lang__opt[data-set-lang='es'] {
        color: var(--accent);
        font-weight: 700;
        cursor: default;
      }
      .lang__sep {
        color: var(--text-dim);
        opacity: 0.5;
      }

      /* ---- Theme toggle (sun/moon, shows the target theme) ---- */
      .nav__theme {
        display: inline-flex;
      }
      .theme {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        color: var(--text-dim);
        transition: color 0.25s var(--ease);
      }
      .theme:hover,
      .theme:focus-visible {
        color: var(--accent);
      }
      .theme__icon {
        display: block;
      }
      /* Dark → offer the sun (go light); light → offer the moon (go dark). */
      :global(html[data-theme='dark']) .theme__icon--moon,
      :global(html[data-theme='light']) .theme__icon--sun {
        display: none;
      }
    </style>

    <script>
      // One IntersectionObserver drives both the page-load hero stagger
      // (elements already in view) and scroll reveals. Re-init on each
      // View Transition navigation via astro:page-load.
      function initReveals() {
        const items = document.querySelectorAll<HTMLElement>('[data-reveal]')
        if (!items.length) return

        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches
        if (reduce) {
          items.forEach((el) => el.classList.add('is-visible'))
          return
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        )
        items.forEach((el) => io.observe(el))
      }

      initReveals()
      document.addEventListener('astro:page-load', initReveals)

      // Accessible "Galerías" dropdown. The <header> uses transition:persist,
      // so the nav DOM survives View Transitions — we bind listeners once
      // (guarded by data-nav-ready) and only reset the open/closed state on
      // each astro:page-load.
      function initNavDropdown() {
        const dd = document.querySelector<HTMLElement>('.nav__dropdown')
        if (!dd) return
        const trigger = dd.querySelector<HTMLButtonElement>('.nav__trigger')
        const menu = dd.querySelector<HTMLElement>('.nav__menu')
        if (!trigger || !menu) return

        const isOpen = () => trigger.getAttribute('aria-expanded') === 'true'
        const open = () => {
          trigger.setAttribute('aria-expanded', 'true')
          menu.hidden = false
        }
        const close = (focusTrigger: boolean) => {
          trigger.setAttribute('aria-expanded', 'false')
          menu.hidden = true
          if (focusTrigger) trigger.focus()
        }
        const links = () => Array.from(menu.querySelectorAll<HTMLAnchorElement>('a'))

        // Always start closed after (re)init / navigation.
        close(false)

        // Bind interaction handlers only once for the persisted nav.
        if (dd.dataset.navReady === 'true') return
        dd.dataset.navReady = 'true'

        // Click / Enter / Space (native on <button>) toggles.
        trigger.addEventListener('click', () => {
          isOpen() ? close(false) : open()
        })

        trigger.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault()
            if (!isOpen()) open()
            links()[0]?.focus()
          } else if (e.key === 'Escape') {
            if (isOpen()) close(true)
          }
        })

        menu.addEventListener('keydown', (e) => {
          const list = links()
          const i = list.indexOf(document.activeElement as HTMLAnchorElement)
          if (e.key === 'Escape') {
            e.preventDefault()
            close(true)
          } else if (e.key === 'ArrowDown') {
            e.preventDefault()
            list[Math.min(i + 1, list.length - 1)]?.focus()
          } else if (e.key === 'ArrowUp') {
            e.preventDefault()
            if (i <= 0) close(true)
            else list[i - 1]?.focus()
          } else if (e.key === 'Home') {
            e.preventDefault()
            list[0]?.focus()
          } else if (e.key === 'End') {
            e.preventDefault()
            list[list.length - 1]?.focus()
          }
        })

        // Close on outside click.
        document.addEventListener('click', (e) => {
          if (isOpen() && !dd.contains(e.target as Node)) close(false)
        })
        // Close when focus leaves the dropdown entirely (Tab out).
        dd.addEventListener('focusout', (e) => {
          if (!dd.contains(e.relatedTarget as Node)) close(false)
        })
      }

      initNavDropdown()
      document.addEventListener('astro:page-load', initNavDropdown)

      // Mobile hamburger. The nav is persisted across View Transitions, so we
      // bind the toggle once and only reset the open/closed state on navigation.
      function initNavBurger() {
        const nav = document.querySelector<HTMLElement>('.nav')
        const burger = document.querySelector<HTMLButtonElement>('[data-nav-burger]')
        if (!nav || !burger) return

        const setOpen = (open: boolean) => {
          nav.setAttribute('data-menu-open', String(open))
          burger.setAttribute('aria-expanded', String(open))
          burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
          // Lock page scroll behind the full-screen overlay.
          document.body.style.overflow = open ? 'hidden' : ''
        }

        // Always start closed after (re)init / navigation.
        setOpen(false)

        if (burger.dataset.burgerReady === 'true') return
        burger.dataset.burgerReady = 'true'

        burger.addEventListener('click', () => {
          setOpen(nav.getAttribute('data-menu-open') !== 'true')
        })
        // Following any link inside the panel closes it.
        nav
          .querySelectorAll<HTMLAnchorElement>('.nav__links a')
          .forEach((a) => a.addEventListener('click', () => setOpen(false)))
        // Escape closes the panel.
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false)
        })
      }

      initNavBurger()
      document.addEventListener('astro:page-load', initNavBurger)

      // Language toggle. The site is English-first: on every full page load it
      // starts in English (we never persist to storage). CSS shows the active
      // language via <html data-lang>; this only flips the attribute. The state
      // is held on `window` so it survives client-side View Transitions but
      // resets to English on a hard reload.
      type Lang = 'en' | 'es'
      const w = window as unknown as { __lang?: Lang }

      function applyLang(lang: Lang) {
        const root = document.documentElement
        root.setAttribute('lang', lang)
        root.setAttribute('data-lang', lang)
        document
          .querySelectorAll<HTMLButtonElement>('[data-set-lang]')
          .forEach((b) =>
            b.setAttribute('aria-pressed', String(b.dataset.setLang === lang))
          )
      }

      function initLang() {
        w.__lang = w.__lang || 'en'
        applyLang(w.__lang)

        // The nav is persisted across View Transitions — bind each option once.
        document
          .querySelectorAll<HTMLButtonElement>('[data-set-lang]')
          .forEach((b) => {
            if (b.dataset.langReady === 'true') return
            b.dataset.langReady = 'true'
            b.addEventListener('click', () => {
              w.__lang = (b.dataset.setLang as Lang) || 'en'
              applyLang(w.__lang)
            })
          })
      }

      initLang()
      document.addEventListener('astro:page-load', initLang)

      // Theme toggle. Unlike language, the choice IS persisted (localStorage)
      // so the site remembers it across visits. Default dark. The anti-flash
      // inline script in <head> applies the saved theme before first paint;
      // this rebinds the button and re-applies on View Transition navigations.
      type Theme = 'dark' | 'light'

      function applyTheme(theme: Theme) {
        document.documentElement.setAttribute('data-theme', theme)
        const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]')
        if (btn) {
          btn.setAttribute(
            'aria-label',
            theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'
          )
        }
      }

      function initTheme() {
        let saved: string | null = null
        try {
          saved = localStorage.getItem('theme')
        } catch (e) {}
        applyTheme(saved === 'light' ? 'light' : 'dark')

        const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]')
        if (!btn) return
        if (btn.dataset.themeReady === 'true') return
        btn.dataset.themeReady = 'true'
        btn.addEventListener('click', () => {
          const next: Theme =
            document.documentElement.getAttribute('data-theme') === 'dark'
              ? 'light'
              : 'dark'
          try {
            localStorage.setItem('theme', next)
          } catch (e) {}
          applyTheme(next)
        })
      }

      initTheme()
      document.addEventListener('astro:page-load', initTheme)
    </script>
  </body>
</html>
