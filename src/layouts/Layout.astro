---
import '@fontsource-variable/playfair-display'
import '@fontsource/space-grotesk/400.css'
import '@fontsource/space-grotesk/500.css'
import '@fontsource/space-grotesk/700.css'
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import { getSiteSettings, getCategories } from '../lib/queries'
import { urlFor } from '../lib/image'

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props

const [settings, categories] = await Promise.all([
  getSiteSettings(),
  getCategories(),
])

const brand = settings.title
const metaDescription =
  description ||
  settings.shortBioEn ||
  settings.shortBio ||
  `${settings.title} — ${settings.tagline}. Photography portfolio.`

// Canonical + Open Graph. Astro.site comes from astro.config (set per env).
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href
const ogSource =
  settings.featured[0] ?? categories.find((c) => c.cover)?.cover ?? null
const ogImage = ogSource
  ? urlFor(ogSource).width(1200).height(630).fit('crop').auto('format').url()
  : null
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph / Twitter — link previews on WhatsApp, IG, X, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <ClientRouter />
  </head>
  <body>
    <a class="skip" href="#main">
      <span data-lang-block="en">Skip to content</span
      ><span data-lang-block="es">Saltar al contenido</span>
    </a>

    <header class="nav wrap" transition:persist>
      <a class="nav__brand" href="/">{brand}</a>
      <button
        class="nav__burger"
        type="button"
        aria-expanded="false"
        aria-controls="nav-links"
        aria-label="Open menu"
        data-nav-burger
      >
        <span class="nav__burger-lines" aria-hidden="true"></span>
      </button>
      <nav aria-label="Main navigation">
        <ul class="nav__links" id="nav-links">
          {
            categories.length > 0 && (
              <li class="nav__dropdown">
                <button
                  class="nav__trigger"
                  type="button"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="nav-galerias"
                >
                  <span data-lang-block="en">Galleries</span>
                  <span data-lang-block="es">Galerías</span>
                  <svg
                    class="nav__caret"
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    aria-hidden="true"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                  >
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </button>
                <ul class="nav__menu" id="nav-galerias" hidden>
                  {categories.map((c) => (
                    <li>
                      <a href={`/${c.slug}`}>{c.title}</a>
                    </li>
                  ))}
                </ul>
              </li>
            )
          }
          <li>
            <a href="/sobre">
              <span data-lang-block="en">About</span
              ><span data-lang-block="es">Sobre</span>
            </a>
          </li>
          <li>
            <a href="/contacto">
              <span data-lang-block="en">Contact</span
              ><span data-lang-block="es">Contacto</span>
            </a>
          </li>
          <li class="nav__lang">
            <button class="lang" type="button" data-lang-toggle aria-label="Cambiar a español">
              <span class="lang__flag" data-lang-block="en" aria-hidden="true">
                <svg viewBox="0 0 60 40" width="22" height="15">
                  <clipPath id="flag-gb"><rect width="60" height="40" rx="4" /></clipPath>
                  <g clip-path="url(#flag-gb)">
                    <rect width="60" height="40" fill="#012169" />
                    <path d="M0,0 60,40 M60,0 0,40" stroke="#fff" stroke-width="8" />
                    <path d="M0,0 60,40 M60,0 0,40" stroke="#C8102E" stroke-width="4" />
                    <path d="M30,0 V40 M0,20 H60" stroke="#fff" stroke-width="12" />
                    <path d="M30,0 V40 M0,20 H60" stroke="#C8102E" stroke-width="6" />
                  </g>
                </svg>
              </span>
              <span class="lang__flag" data-lang-block="es" aria-hidden="true">
                <svg viewBox="0 0 60 40" width="22" height="15">
                  <clipPath id="flag-ar"><rect width="60" height="40" rx="4" /></clipPath>
                  <g clip-path="url(#flag-ar)">
                    <rect width="60" height="40" fill="#fff" />
                    <rect width="60" height="13.33" fill="#74acdf" />
                    <rect y="26.67" width="60" height="13.33" fill="#74acdf" />
                    <circle cx="30" cy="20" r="3.6" fill="#f6b40e" />
                  </g>
                </svg>
              </span>
              <span class="lang__code" data-lang-block="en">EN</span
              ><span class="lang__code" data-lang-block="es">ES</span>
            </button>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer wrap">
      <hr class="rule" />
      <div class="footer__row">
        <p class="footer__brand">{brand}</p>
        <ul class="footer__meta">
          {settings.instagram && (
            <li>
              <a
                class="footer__ig"
                href={`https://instagram.com/${settings.instagram.replace('@', '')}`}
                rel="me noopener"
                target="_blank"
                aria-label="Instagram"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  aria-hidden="true"
                >
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
                </svg>
              </a>
            </li>
          )}
          {settings.email && (
            <li><a href={`mailto:${settings.email}`}>{settings.email}</a></li>
          )}
          <li><span>© {new Date().getFullYear()}</span></li>
        </ul>
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        z-index: 200;
        padding: 0.6rem 1rem;
        background: var(--accent);
        color: var(--bg);
        font-weight: 500;
        transform: translateY(-160%);
        transition: transform 0.2s var(--ease);
      }
      .skip:focus {
        transform: translateY(0);
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        padding-block: clamp(1rem, 2vw, 1.6rem);
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .nav__brand {
        font-family: var(--font-display);
        font-size: var(--step-1);
        font-weight: 400;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .nav__links {
        display: flex;
        align-items: center;
        gap: clamp(0.9rem, 2.4vw, 2.2rem);
        font-size: var(--step--1);
        letter-spacing: 0.02em;
      }
      .nav__links a {
        position: relative;
        padding-block: 0.2rem;
        color: var(--text-dim);
        transition: color 0.3s var(--ease);
      }
      .nav__links a::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s var(--ease);
      }
      .nav__links a:hover,
      .nav__links a:focus-visible {
        color: var(--text);
      }
      .nav__links a:hover::after,
      .nav__links a:focus-visible::after {
        transform: scaleX(1);
      }

      /* ---- Galerías dropdown ---- */
      .nav__dropdown {
        position: relative;
      }
      .nav__trigger {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.2rem 0;
        font-family: inherit;
        font-size: var(--step--1);
        letter-spacing: 0.02em;
        color: var(--text-dim);
        transition: color 0.3s var(--ease);
      }
      .nav__trigger::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s var(--ease);
      }
      .nav__trigger:hover,
      .nav__trigger:focus-visible,
      .nav__trigger[aria-expanded='true'] {
        color: var(--text);
      }
      .nav__trigger:hover::after,
      .nav__trigger:focus-visible::after,
      .nav__trigger[aria-expanded='true']::after {
        transform: scaleX(1);
      }
      .nav__caret {
        transition: transform 0.3s var(--ease);
      }
      .nav__trigger[aria-expanded='true'] .nav__caret {
        transform: rotate(180deg);
      }

      .nav__menu {
        position: absolute;
        top: calc(100% + 0.9rem);
        left: 0;
        z-index: 120;
        display: grid;
        gap: 0.15rem;
        min-width: max(11rem, 100%);
        max-width: min(72vw, 18rem);
        padding: 0.5rem;
        background: color-mix(in srgb, var(--surface) 92%, transparent);
        backdrop-filter: blur(14px);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.45);
      }
      .nav__menu[hidden] {
        display: none;
      }
      .nav__menu li {
        margin: 0;
      }
      .nav__menu a {
        display: block;
        padding: 0.55rem 0.7rem;
        font-size: var(--step--1);
        letter-spacing: 0.02em;
        color: var(--text-dim);
        border-radius: var(--radius);
        transition: color 0.25s var(--ease), background 0.25s var(--ease);
      }
      .nav__menu a:hover,
      .nav__menu a:focus-visible {
        color: var(--text);
        background: color-mix(in srgb, var(--accent) 16%, transparent);
        outline: none;
      }
      /* ---- Mobile hamburger ---- */
      .nav__burger {
        display: none;
      }
      @media (max-width: 640px) {
        .nav {
          align-items: center;
        }
        .nav__burger {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          width: 2.4rem;
          height: 2.4rem;
          color: var(--text);
          z-index: 130;
        }
        .nav__burger-lines,
        .nav__burger-lines::before,
        .nav__burger-lines::after {
          display: block;
          width: 22px;
          height: 1.6px;
          background: currentColor;
          transition: transform 0.3s var(--ease), background 0.2s var(--ease);
        }
        .nav__burger-lines {
          position: relative;
        }
        .nav__burger-lines::before,
        .nav__burger-lines::after {
          content: '';
          position: absolute;
          left: 0;
        }
        .nav__burger-lines::before {
          top: -7px;
        }
        .nav__burger-lines::after {
          top: 7px;
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines {
          background: transparent;
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines::before {
          transform: translateY(7px) rotate(45deg);
        }
        .nav__burger[aria-expanded='true'] .nav__burger-lines::after {
          transform: translateY(-7px) rotate(-45deg);
        }

        /* Links collapse into a dropdown panel under the header. */
        .nav__links {
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: flex-start;
          gap: 1.3rem;
          padding: 1.4rem var(--gutter) 1.9rem;
          font-size: var(--step-0);
          background: color-mix(in srgb, var(--bg) 96%, transparent);
          backdrop-filter: blur(14px);
          border-bottom: 1px solid var(--line);
          transform: translateY(-10px);
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
          transition: transform 0.3s var(--ease), opacity 0.3s var(--ease),
            visibility 0s linear 0.3s;
        }
        .nav[data-menu-open='true'] .nav__links {
          transform: none;
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
          transition: transform 0.3s var(--ease), opacity 0.3s var(--ease),
            visibility 0s linear 0s;
        }

        /* The Galleries submenu sits inline within the panel, not floating. */
        .nav__menu {
          position: static;
          min-width: 0;
          max-width: none;
          margin-top: 0.4rem;
          padding: 0.25rem 0 0 0.6rem;
          background: transparent;
          border: none;
          box-shadow: none;
          backdrop-filter: none;
        }
        .nav__lang {
          margin-top: 0.3rem;
        }
      }

      .footer {
        margin-top: clamp(4rem, 10vw, 9rem);
        padding-bottom: 2.5rem;
      }
      .footer__row {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 1.5rem;
      }
      .footer__brand {
        font-family: var(--font-display);
        font-size: var(--step-2);
      }
      .footer__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.4rem;
        font-size: var(--step--1);
        color: var(--text-dim);
      }
      .footer__meta a:hover {
        color: var(--accent);
      }
      .footer__ig {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      /* ---- Language toggle ---- */
      .nav__lang {
        display: inline-flex;
      }
      .lang {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.25rem 0.55rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--text-dim);
        font-size: var(--step--2);
        font-weight: 500;
        letter-spacing: 0.08em;
        transition: color 0.3s var(--ease), border-color 0.3s var(--ease);
      }
      .lang:hover,
      .lang:focus-visible {
        color: var(--text);
        border-color: var(--accent);
      }
      .lang__flag {
        display: inline-flex;
      }
      .lang__flag svg {
        border-radius: 3px;
        display: block;
      }
    </style>

    <script>
      // One IntersectionObserver drives both the page-load hero stagger
      // (elements already in view) and scroll reveals. Re-init on each
      // View Transition navigation via astro:page-load.
      function initReveals() {
        const items = document.querySelectorAll<HTMLElement>('[data-reveal]')
        if (!items.length) return

        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches
        if (reduce) {
          items.forEach((el) => el.classList.add('is-visible'))
          return
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        )
        items.forEach((el) => io.observe(el))
      }

      initReveals()
      document.addEventListener('astro:page-load', initReveals)

      // Accessible "Galerías" dropdown. The <header> uses transition:persist,
      // so the nav DOM survives View Transitions — we bind listeners once
      // (guarded by data-nav-ready) and only reset the open/closed state on
      // each astro:page-load.
      function initNavDropdown() {
        const dd = document.querySelector<HTMLElement>('.nav__dropdown')
        if (!dd) return
        const trigger = dd.querySelector<HTMLButtonElement>('.nav__trigger')
        const menu = dd.querySelector<HTMLElement>('.nav__menu')
        if (!trigger || !menu) return

        const isOpen = () => trigger.getAttribute('aria-expanded') === 'true'
        const open = () => {
          trigger.setAttribute('aria-expanded', 'true')
          menu.hidden = false
        }
        const close = (focusTrigger: boolean) => {
          trigger.setAttribute('aria-expanded', 'false')
          menu.hidden = true
          if (focusTrigger) trigger.focus()
        }
        const links = () => Array.from(menu.querySelectorAll<HTMLAnchorElement>('a'))

        // Always start closed after (re)init / navigation.
        close(false)

        // Bind interaction handlers only once for the persisted nav.
        if (dd.dataset.navReady === 'true') return
        dd.dataset.navReady = 'true'

        // Click / Enter / Space (native on <button>) toggles.
        trigger.addEventListener('click', () => {
          isOpen() ? close(false) : open()
        })

        trigger.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault()
            if (!isOpen()) open()
            links()[0]?.focus()
          } else if (e.key === 'Escape') {
            if (isOpen()) close(true)
          }
        })

        menu.addEventListener('keydown', (e) => {
          const list = links()
          const i = list.indexOf(document.activeElement as HTMLAnchorElement)
          if (e.key === 'Escape') {
            e.preventDefault()
            close(true)
          } else if (e.key === 'ArrowDown') {
            e.preventDefault()
            list[Math.min(i + 1, list.length - 1)]?.focus()
          } else if (e.key === 'ArrowUp') {
            e.preventDefault()
            if (i <= 0) close(true)
            else list[i - 1]?.focus()
          } else if (e.key === 'Home') {
            e.preventDefault()
            list[0]?.focus()
          } else if (e.key === 'End') {
            e.preventDefault()
            list[list.length - 1]?.focus()
          }
        })

        // Close on outside click.
        document.addEventListener('click', (e) => {
          if (isOpen() && !dd.contains(e.target as Node)) close(false)
        })
        // Close when focus leaves the dropdown entirely (Tab out).
        dd.addEventListener('focusout', (e) => {
          if (!dd.contains(e.relatedTarget as Node)) close(false)
        })
      }

      initNavDropdown()
      document.addEventListener('astro:page-load', initNavDropdown)

      // Mobile hamburger. The nav is persisted across View Transitions, so we
      // bind the toggle once and only reset the open/closed state on navigation.
      function initNavBurger() {
        const nav = document.querySelector<HTMLElement>('.nav')
        const burger = document.querySelector<HTMLButtonElement>('[data-nav-burger]')
        if (!nav || !burger) return

        const setOpen = (open: boolean) => {
          nav.setAttribute('data-menu-open', String(open))
          burger.setAttribute('aria-expanded', String(open))
          burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
        }

        // Always start closed after (re)init / navigation.
        setOpen(false)

        if (burger.dataset.burgerReady === 'true') return
        burger.dataset.burgerReady = 'true'

        burger.addEventListener('click', () => {
          setOpen(nav.getAttribute('data-menu-open') !== 'true')
        })
        // Following any link inside the panel closes it.
        nav
          .querySelectorAll<HTMLAnchorElement>('.nav__links a')
          .forEach((a) => a.addEventListener('click', () => setOpen(false)))
        // Escape closes the panel.
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false)
        })
      }

      initNavBurger()
      document.addEventListener('astro:page-load', initNavBurger)

      // Language toggle. The site is English-first: on every full page load it
      // starts in English (we never persist to storage). CSS shows the active
      // language via <html data-lang>; this only flips the attribute. The state
      // is held on `window` so it survives client-side View Transitions but
      // resets to English on a hard reload.
      type Lang = 'en' | 'es'
      const w = window as unknown as { __lang?: Lang }

      function applyLang(lang: Lang) {
        const root = document.documentElement
        root.setAttribute('lang', lang)
        root.setAttribute('data-lang', lang)
        const btn = document.querySelector<HTMLButtonElement>('[data-lang-toggle]')
        if (btn) {
          btn.setAttribute(
            'aria-label',
            lang === 'en' ? 'Cambiar a español' : 'Switch to English'
          )
        }
      }

      function initLang() {
        w.__lang = w.__lang || 'en'
        applyLang(w.__lang)

        const btn = document.querySelector<HTMLButtonElement>('[data-lang-toggle]')
        if (!btn) return
        // The nav is persisted across View Transitions — bind the click once.
        if (btn.dataset.langReady === 'true') return
        btn.dataset.langReady = 'true'
        btn.addEventListener('click', () => {
          w.__lang = w.__lang === 'en' ? 'es' : 'en'
          applyLang(w.__lang)
        })
      }

      initLang()
      document.addEventListener('astro:page-load', initLang)
    </script>
  </body>
</html>
